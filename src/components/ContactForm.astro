<form
  id="contact-form"
  name="contact-v2"
  method="POST"
  netlify-honeypot="bot-field"
  data-netlify="true"
  class="space-y-8"
  aria-label="Contact form"
>
  <p class="hidden" aria-hidden="true">
    <label>Don't fill this out if you're human: <input name="bot-field" /></label>
  </p>

  <!-- Name -->
  <div>
    <label
      for="sender"
      class="block text-[11px] font-bold tracking-[0.2em] uppercase text-stone-700 mb-2"
    >
      Name
    </label>
    <input
      id="sender"
      name="sender"
      type="text"
      placeholder="Your name"
      autocomplete="name"
      required
      class="w-full border-b-2 border-stone-700 bg-transparent py-2.5 text-base text-stone-900 focus:border-red-700 focus:outline-none focus:bg-white placeholder-stone-400 transition-colors"
    />
  </div>

  <!-- Email -->
  <div>
    <label
      for="email"
      class="block text-[11px] font-bold tracking-[0.2em] uppercase text-stone-700 mb-2"
    >
      Email Address
    </label>
    <input
      id="email"
      name="email"
      type="email"
      placeholder="you@example.com"
      autocomplete="email"
      required
      class="w-full border-b-2 border-stone-700 bg-transparent py-2.5 text-base text-stone-900 focus:border-red-700 focus:outline-none focus:bg-white placeholder-stone-400 transition-colors"
    />
  </div>

  <!-- Message -->
  <div>
    <label
      for="message"
      class="block text-[11px] font-bold tracking-[0.2em] uppercase text-stone-700 mb-2"
    >
      Message
    </label>
    <textarea
      id="message"
      name="message"
      placeholder="Tell me about your project..."
      rows="4"
      data-min-rows="4"
      required
      class="w-full border-b-2 border-stone-700 bg-transparent py-2.5 text-base text-stone-900 focus:border-red-700 focus:outline-none focus:bg-white placeholder-stone-400 transition-colors resize-none"
    ></textarea>
  </div>

  <!-- Submit -->
  <div class="pt-2">
    <button
      id="submit"
      type="submit"
      disabled
      title="Fill in your name, a valid email address, and a message to send"
      class="px-10 py-3 bg-red-700 text-white text-[11px] font-bold tracking-[0.2em] uppercase rounded-full transition-colors enabled:hover:bg-red-800 enabled:cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
    >
      Send Message
    </button>
    <p id="submit-hint" class="mt-3 text-[11px] tracking-wide text-stone-700">
      Name, email, and message required
    </p>
  </div>
</form>

<!-- Success state: tabindex="-1" allows JS to programmatically focus it for keyboard users -->
<div id="success" class="hidden" role="status" aria-live="polite" tabindex="-1">
  <div class="border-l-4 border-red-700 pl-6 py-2">
    <p class="text-[11px] font-bold tracking-[0.2em] uppercase text-stone-600 mb-3">
      Message Received
    </p>
    <p class="font-serif text-3xl font-black text-stone-900">Thank you.</p>
    <p class="text-sm text-stone-700 mt-2">I'll be in touch shortly.</p>
  </div>
</div>

<script>
  import { initContactForm } from './contact-form-client.js';

  if (typeof window !== 'undefined') {
    Promise.resolve().then(() => {
      try {
        initContactForm();
      } catch (err) {
        console.error('contact form init failed', err);
      }
    });
  }
</script>
