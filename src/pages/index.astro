---
import '../styles/global.css';
import { Image } from 'astro:assets';
import ContactForm from '../components/ContactForm.astro';
import eyewitness from '../assets/eyewitness.jpg';

const siteTitle = 'Tyler Campbell';
const siteDescription =
  'Tyler Campbell — Designer and Developer making engaging elearning and digital experiences in Georgia.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Prevent flash of wrong theme before CSS loads -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="author" content={siteTitle} />

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content="/og.jpg" />

    <link rel="canonical" href="https://www.tylercampbell.com/" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link
      rel="preload"
      href="/Nunito-VariableFont_wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <!-- Theme toggle: zero-height container so it doesn't affect layout; -->
    <div class="relative h-0">
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="absolute top-3 right-3 p-2 rounded-sm border border-trim bg-surface text-dim hover:bg-trim transition-colors cursor-pointer"
      >
        <!-- Moon: shown in light mode -->
        <svg
          id="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <!-- Sun: shown in dark mode -->
        <svg
          id="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="hidden"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
      </button>
    </div>

    <main>
      <!-- Hero -->
      <section
        class="flex flex-col items-center justify-center gap-6 p-6"
        style="min-height: 100vh;"
        aria-label="Tyler Campbell — Designer, Developer"
      >
        <a
          href="#contact"
          aria-label="Scroll to contact form"
          class="rounded-sm shadow-[0_20px_60px_rgba(0,0,0,0.38)] cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
        >
          <Image
            src={eyewitness}
            format="webp"
            width={1200}
            height={1542}
            alt="Tyler Campbell — Designer, Developer: Discover how engaging elearning comes to life through motion design, interactive courses, and thoughtfully crafted digital instruction"
            style="max-height: min(82vh, 720px); width: auto;"
            class="block max-w-full rounded-sm"
            loading="eager"
            fetchpriority="high"
          />
        </a>
        <a
          href="#contact"
          class="text-ghost hover:text-ink transition-colors"
          aria-hidden="true"
          tabindex="-1"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"></path></svg
          >
        </a>
      </section>

      <!-- Contact section -->
      <section id="contact" class="flex flex-col min-h-screen">
        <div class="flex-1 w-full max-w-xl mx-auto py-20 px-6">
          <div class="mb-12">
            <span
              class="inline-block border text-dim border-dim px-3 leading-5 text-[10px] tracking-[0.25em] uppercase mb-5"
              >Contact</span
            >
            <h2 class="font-serif text-4xl font-black leading-tight mb-3 text-ink">Say Hello</h2>
            <div class="w-14 h-[3px] bg-accent"></div>
          </div>

          <ContactForm />

          <div class="mt-12 pt-8 border-t border-trim">
            <p class="text-[10px] font-bold tracking-[0.2em] uppercase mb-2 text-dim">
              Prefer Email?
            </p>
            <a
              href="mailto:hello@tylercampbell.com"
              class="font-bold text-lg hover:underline underline-offset-2 transition-colors text-ink"
            >
              hello@tylercampbell.com
            </a>
          </div>
        </div>

        <p class="py-8 text-center text-[10px] tracking-[0.2em] uppercase text-dim">
          &copy; {new Date().getFullYear()} Tyler Campbell
        </p>
      </section>
    </main>

    <script is:inline>
      const btn = document.getElementById('theme-toggle');
      const moon = document.getElementById('icon-moon');
      const sun = document.getElementById('icon-sun');

      function syncIcons() {
        const dark = document.documentElement.classList.contains('dark');
        moon?.classList.toggle('hidden', dark);
        sun?.classList.toggle('hidden', !dark);
      }

      syncIcons();

      btn?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncIcons();
      });
    </script>
  </body>
</html>
