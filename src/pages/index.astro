---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import ContactForm from '../components/ContactForm.astro';
import eyewitness from '../assets/eyewitness.jpg';

const siteTitle = 'Tyler Campbell';
const siteDescription =
  'Tyler Campbell — Designer and Developer making engaging elearning and digital experiences in Georgia.';
---

<Layout>
  <Fragment slot="head">
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="author" content={siteTitle} />

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content="/og.jpg" />

    <link rel="canonical" href="https://www.tylercampbell.com/" />
    <link
      rel="preload"
      href="/Nunito-VariableFont_wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </Fragment>

  <main>
    <!-- Hero -->
    <section
      class="flex flex-col items-center justify-center gap-6 p-6"
      style="min-height: 100vh;"
      aria-label="Tyler Campbell — Designer, Developer"
    >
      <a
        href="#contact"
        aria-label="Scroll to contact form"
        class="rounded-sm shadow-[0_20px_60px_rgba(0,0,0,0.38)] cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
      >
        <Image
          src={eyewitness}
          format="webp"
          width={1200}
          height={1542}
          alt="Tyler Campbell — Designer, Developer: Discover how engaging elearning comes to life through motion design, interactive courses, and thoughtfully crafted digital instruction"
          style="max-height: min(82vh, 720px); width: auto;"
          class="block max-w-full rounded-sm"
          loading="eager"
          fetchpriority="high"
        />
      </a>
      <a
        href="#contact"
        class="text-[var(--color-text-subtle)] hover:text-[var(--color-text)] transition-colors"
        aria-hidden="true"
        tabindex="-1"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"></path></svg
        >
      </a>
    </section>

    <!-- Contact section -->
    <section id="contact" class="flex flex-col min-h-screen">
      <div class="flex-1 w-full max-w-xl mx-auto py-20 px-6">

        <div class="mb-12">
          <span class="section-tag">Contact</span>
          <h2 class="section-heading">Say Hello</h2>
          <div class="section-rule"></div>
        </div>

        <ContactForm />

        <div class="mt-12 pt-8 border-t border-[var(--color-border)]">
          <p class="text-[10px] font-bold tracking-[0.2em] uppercase mb-2 text-[var(--color-text-muted)]">
            Prefer Email?
          </p>
          <a
            href="mailto:hello@tylercampbell.com"
            class="font-bold text-lg hover:underline underline-offset-2 transition-colors text-[var(--color-accent)]"
          >
            hello@tylercampbell.com
          </a>
        </div>

      </div>

      <p class="py-8 text-center text-[10px] tracking-[0.2em] uppercase text-[var(--color-text-muted)]">
        &copy; {new Date().getFullYear()} Tyler Campbell
      </p>
    </section>
  </main>
</Layout>
